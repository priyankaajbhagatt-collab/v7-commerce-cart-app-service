    "aws-cdk-lib": "^2.140.0",
    "constructs": "^10.3.0",
    "aws-cdk": "^2.140.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
